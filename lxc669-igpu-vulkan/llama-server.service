[Unit]
Description=Llama.cpp Vulkan Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/app/ai-engine/llama.cpp/build
LimitMEMLOCK=infinity
ExecStart=/app/ai-engine/llama.cpp/build/bin/llama-server \
  -m /app/ai-engine/models/Tir-na-AI.gguf \
  -a "Tir-na-AI" \
  --api-key tir-na-ai-key \
  -ngl 99 \
  --host 0.0.0.0 \
  --port 8080 \
  -c 4096 \
  --no-mmap
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
