[Unit]
Description=Llama.cpp Vulkan Server (Tír-na-AI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/app/ai-engine/llama.cpp/build
LimitMEMLOCK=infinity
ExecStart=/app/ai-engine/llama.cpp/build/bin/llama-server \
  -m PLACEHOLDER_MODEL_PATH \
  -a "Tir-na-AI" \
  --api-key PLACEHOLDER_KEY \
  -ngl 99 \
  --host PLACEHOLDER_IP \
  --port 8080 \
  -c 4096 \
  --no-mmap
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
